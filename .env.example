RAYIP_SERVICE_ENV=dev
RAYIP_HTTP_ADDR=:8080
RAYIP_GRPC_ADDR=:9090
RAYIP_POSTGRES_DSN=postgres://rayip:rayip@localhost:5432/rayip?sslmode=disable
RAYIP_POSTGRES_RUN_MIGRATIONS=true
RAYIP_REDIS_ADDR=localhost:6379
RAYIP_NATS_URL=nats://localhost:4222
RAYIP_NODE_ENROLLMENT_TOKEN=dev-enrollment-token

RAYIP_AGENT_NODE_CODE=local-home-001
RAYIP_AGENT_ENROLLMENT_TOKEN=dev-enrollment-token
RAYIP_AGENT_API_GRPC_ADDR=127.0.0.1:9090
RAYIP_AGENT_RUNTIME_BUNDLE_DIR=/opt/rayip/runtime
RAYIP_AGENT_RUNTIME_CORE_MODE=xray
RAYIP_AGENT_RUNTIME_XRAY_GRPC_ADDR=auto
RAYIP_AGENT_RUNTIME_XRAY_AUTO_START=true
